{
  "id": "Rainbow",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/skydimo/skydimo-plugins",
  "license": "GPL-2.0-or-later",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Waves",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 2.5,
      "min": 0,
      "max": 5,
      "step": 0.1
    },
    {
      "key": "preset",
      "label": "params.preset",
      "group": "params.groups.palette",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.presetOptions.rainbow",
          "value": 1
        },
        {
          "label": "params.presetOptions.sunset",
          "value": 2
        },
        {
          "label": "params.presetOptions.ocean",
          "value": 3
        },
        {
          "label": "params.presetOptions.synthwave",
          "value": 4
        },
        {
          "label": "params.presetOptions.custom",
          "value": 0
        }
      ]
    },
    {
      "key": "colors",
      "label": "params.colors",
      "group": "params.groups.palette",
      "kind": "multi-color",
      "default": [
        "#FF0000",
        "#FF9900",
        "#FFFF00",
        "#00FF88",
        "#00AAFF",
        "#AA00FF"
      ],
      "minCount": 2,
      "dependency": {
        "key": "preset",
        "equals": 0,
        "behavior": "hide"
      }
    }
  ]
}
