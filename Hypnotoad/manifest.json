{
  "id": "Hypnotoad",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/Skydimo-Team/OpenRGBEffectsPlugin",
  "license": "GPL-2.0-or-later",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Orbit",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100,
      "step": 1
    },
    {
      "key": "color_mode",
      "label": "params.colorMode",
      "group": "params.groups.color",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.colorModeOptions.rainbow",
          "value": 0
        },
        {
          "label": "params.colorModeOptions.custom",
          "value": 1
        }
      ]
    },
    {
      "key": "colors",
      "label": "params.colors",
      "group": "params.groups.color",
      "kind": "multi-color",
      "default": [
        "#000000"
      ],
      "minCount": 1,
      "maxCount": 100,
      "dependency": {
        "key": "color_mode",
        "equals": 1,
        "behavior": "hide"
      }
    },
    {
      "key": "color_rotation_speed",
      "label": "params.colorRotationSpeed",
      "group": "params.groups.color",
      "kind": "slider",
      "default": 10,
      "min": 10,
      "max": 99,
      "step": 1
    },
    {
      "key": "color_rotation_direction",
      "label": "params.colorRotationDirection",
      "group": "params.groups.color",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.colorRotationDirectionOptions.clockwise",
          "value": 0
        },
        {
          "label": "params.colorRotationDirectionOptions.counterClockwise",
          "value": 1
        }
      ]
    },
    {
      "key": "animation_speed",
      "label": "params.animationSpeed",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 10,
      "min": 10,
      "max": 99,
      "step": 1
    },
    {
      "key": "animation_direction",
      "label": "params.animationDirection",
      "group": "params.groups.animation",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.animationDirectionOptions.inside",
          "value": 0
        },
        {
          "label": "params.animationDirectionOptions.outside",
          "value": 1
        }
      ]
    },
    {
      "key": "spacing",
      "label": "params.spacing",
      "group": "params.groups.geometry",
      "kind": "slider",
      "default": 1,
      "min": 1,
      "max": 10,
      "step": 1
    },
    {
      "key": "thickness",
      "label": "params.thickness",
      "group": "params.groups.geometry",
      "kind": "slider",
      "default": 1,
      "min": 1,
      "max": 10,
      "step": 1
    },
    {
      "key": "cx",
      "label": "params.centerX",
      "group": "params.groups.geometry",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "key": "cy",
      "label": "params.centerY",
      "group": "params.groups.geometry",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    }
  ]
}
