{
  "id": "Lightning",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/skydimo/skydimo-plugins",
  "license": "MIT",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Zap",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 20,
      "min": 1,
      "max": 100,
      "step": 1
    },
    {
      "key": "decay",
      "label": "params.decay",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 10,
      "min": 2,
      "max": 60,
      "step": 1
    },
    {
      "key": "mode",
      "label": "params.mode",
      "group": "params.groups.animation",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.modeOptions.wholeStrip",
          "value": 0
        },
        {
          "label": "params.modeOptions.perLed",
          "value": 1
        }
      ]
    },
    {
      "key": "random",
      "label": "params.random",
      "group": "params.groups.color",
      "kind": "toggle",
      "default": false
    },
    {
      "key": "color",
      "label": "params.color",
      "group": "params.groups.color",
      "kind": "color",
      "default": "#FF0000",
      "dependency": {
        "key": "random",
        "equals": false,
        "behavior": "hide"
      }
    }
  ]
}
