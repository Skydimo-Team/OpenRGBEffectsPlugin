{
  "id": "AudioVuMeter",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/skydimo/skydimo-plugins",
  "license": "MIT",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "AudioLines",
  "permissions": [
    "audio:capture",
    "media:album_art",
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.response",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100
    },
    {
      "key": "avgSize",
      "label": "params.smoothness",
      "group": "params.groups.response",
      "kind": "slider",
      "default": 8,
      "min": 1,
      "max": 16
    },
    {
      "key": "colorOffset",
      "label": "params.colorOffset",
      "group": "params.groups.color",
      "kind": "slider",
      "default": 180,
      "min": 0,
      "max": 360
    },
    {
      "key": "colorSpread",
      "label": "params.colorSpread",
      "group": "params.groups.color",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100
    },
    {
      "key": "saturation",
      "label": "params.saturation",
      "group": "params.groups.color",
      "kind": "slider",
      "default": 100,
      "min": 0,
      "max": 100
    },
    {
      "key": "invertHue",
      "label": "params.invertHue",
      "group": "params.groups.color",
      "kind": "toggle",
      "default": false
    },
    {
      "key": "useAlbumArt",
      "label": "params.useAlbumArt",
      "group": "params.groups.color",
      "kind": "toggle",
      "default": false
    }
  ]
}
