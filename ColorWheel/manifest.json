{
  "id": "ColorWheel",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/Skydimo-Team/OpenRGBEffectsPlugin",
  "license": "GPL-2.0-or-later",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "CircleDot",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "key": "direction",
      "label": "params.direction",
      "group": "params.groups.animation",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.directionOptions.clockwise",
          "value": 0
        },
        {
          "label": "params.directionOptions.counterClockwise",
          "value": 1
        }
      ]
    },
    {
      "key": "cx",
      "label": "params.cx",
      "group": "params.groups.center",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "key": "cy",
      "label": "params.cy",
      "group": "params.groups.center",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    }
  ]
}