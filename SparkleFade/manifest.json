{
  "id": "SparkleFade",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/skydimo/skydimo-plugins",
  "license": "MIT",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Sparkles",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "off_time",
      "label": "params.off_time",
      "group": "params.groups.timing",
      "kind": "slider",
      "default": 0.5,
      "min": 0,
      "max": 10,
      "step": 0.1
    },
    {
      "key": "fade_in_time",
      "label": "params.fade_in_time",
      "group": "params.groups.timing",
      "kind": "slider",
      "default": 3,
      "min": 0.1,
      "max": 10,
      "step": 0.1
    },
    {
      "key": "fade_out_time",
      "label": "params.fade_out_time",
      "group": "params.groups.timing",
      "kind": "slider",
      "default": 10,
      "min": 0.5,
      "max": 30,
      "step": 0.5
    },
    {
      "key": "random",
      "label": "params.random",
      "group": "params.groups.color",
      "kind": "toggle",
      "default": false
    },
    {
      "key": "color",
      "label": "params.color",
      "group": "params.groups.color",
      "kind": "color",
      "default": "#FF0000",
      "dependency": {
        "key": "random",
        "equals": false,
        "behavior": "hide"
      }
    }
  ]
}
