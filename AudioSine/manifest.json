{
  "id": "AudioSine",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/Skydimo-Team/OpenRGBEffectsPlugin",
  "license": "GPL-2.0-or-later",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "AudioLines",
  "permissions": [
    "audio:capture",
    "media:album_art",
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.wave",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100
    },
    {
      "key": "repeat",
      "label": "params.repeat",
      "group": "params.groups.wave",
      "kind": "slider",
      "default": 1,
      "min": 1,
      "max": 40
    },
    {
      "key": "thickness",
      "label": "params.thickness",
      "group": "params.groups.wave",
      "kind": "slider",
      "default": 10,
      "min": 0,
      "max": 100
    },
    {
      "key": "glow",
      "label": "params.glow",
      "group": "params.groups.wave",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100
    },
    {
      "key": "oscillation",
      "label": "params.oscillation",
      "group": "params.groups.wave",
      "kind": "slider",
      "default": 0,
      "min": 0,
      "max": 100
    },
    {
      "key": "avgSize",
      "label": "params.smoothness",
      "group": "params.groups.response",
      "kind": "slider",
      "default": 8,
      "min": 1,
      "max": 16,
      "groupCollapsed": true
    },
    {
      "key": "colorMode",
      "label": "params.colorMode",
      "group": "params.groups.color",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.colorModeOptions.spectrumCycle",
          "value": 0
        },
        {
          "label": "params.colorModeOptions.static",
          "value": 1
        }
      ]
    },
    {
      "key": "colorChangeSpeed",
      "label": "params.colorChangeSpeed",
      "group": "params.groups.color",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100
    },
    {
      "key": "useAlbumArt",
      "label": "params.useAlbumArt",
      "group": "params.groups.color",
      "kind": "toggle",
      "default": false
    },
    {
      "key": "backgroundColor",
      "label": "params.backgroundColor",
      "group": "params.groups.color",
      "kind": "color",
      "default": "#000000"
    },
    {
      "key": "waveColor",
      "label": "params.waveColor",
      "group": "params.groups.color",
      "kind": "color",
      "default": "#00FF00",
      "dependency": {
        "key": "colorMode",
        "behavior": "hide",
        "equals": 1
      }
    }
  ]
}
