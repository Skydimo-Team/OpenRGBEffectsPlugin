{
  "id": "RotatingBeam",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/skydimo/skydimo-plugins",
  "license": "MIT",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Crosshair",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100,
      "step": 1
    },
    {
      "key": "mode",
      "label": "params.mode",
      "group": "params.groups.animation",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.modeOptions.clockwise",
          "value": 0
        },
        {
          "label": "params.modeOptions.counterClockwise",
          "value": 1
        },
        {
          "label": "params.modeOptions.pendulum",
          "value": 2
        },
        {
          "label": "params.modeOptions.wipers",
          "value": 3
        },
        {
          "label": "params.modeOptions.swingH",
          "value": 4
        },
        {
          "label": "params.modeOptions.swingV",
          "value": 5
        }
      ]
    },
    {
      "key": "glow",
      "label": "params.glow",
      "group": "params.groups.appearance",
      "kind": "slider",
      "default": 10,
      "min": 1,
      "max": 50,
      "step": 1
    },
    {
      "key": "thickness",
      "label": "params.thickness",
      "group": "params.groups.appearance",
      "kind": "slider",
      "default": 0,
      "min": 0,
      "max": 99,
      "step": 1
    },
    {
      "key": "random_colors",
      "label": "params.random_colors",
      "group": "params.groups.color",
      "kind": "toggle",
      "default": false
    },
    {
      "key": "colors",
      "label": "params.colors",
      "group": "params.groups.color",
      "kind": "multi-color",
      "default": [
        "#FF0000",
        "#0000FF"
      ],
      "fixedCount": 2,
      "dependency": {
        "key": "random_colors",
        "equals": false,
        "behavior": "hide"
      }
    }
  ]
}
