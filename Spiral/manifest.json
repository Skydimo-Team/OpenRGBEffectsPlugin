{
  "id": "Spiral",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/Skydimo-Team/OpenRGBEffectsPlugin",
  "license": "GPL-2.0-or-later",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Disc3",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100,
      "step": 1
    },
    {
      "key": "shape",
      "label": "params.shape",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 10,
      "min": 1,
      "max": 100,
      "step": 1
    },
    {
      "key": "direction",
      "label": "params.direction",
      "group": "params.groups.animation",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.directionOptions.counterClockwise",
          "value": 0
        },
        {
          "label": "params.directionOptions.clockwise",
          "value": 1
        }
      ]
    },
    {
      "key": "color_mode",
      "label": "params.colorMode",
      "group": "params.groups.color",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.colorModeOptions.rainbow",
          "value": 0
        },
        {
          "label": "params.colorModeOptions.singleColor",
          "value": 1
        }
      ]
    },
    {
      "key": "color",
      "label": "params.color",
      "group": "params.groups.color",
      "kind": "color",
      "default": "#FF0000",
      "dependency": {
        "key": "color_mode",
        "equals": 1,
        "behavior": "hide"
      }
    }
  ]
}
