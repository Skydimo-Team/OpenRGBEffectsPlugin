{
  "id": "Clock",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/skydimo/skydimo-plugins",
  "license": "GPL-2.0-or-later",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Clock",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "clockMode",
      "label": "params.clockMode",
      "group": "params.groups.clock",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.clockModeOptions.12hour",
          "value": 0
        },
        {
          "label": "params.clockModeOptions.24hour",
          "value": 1
        }
      ]
    },
    {
      "key": "hourColor",
      "label": "params.hourColor",
      "group": "params.groups.colors",
      "kind": "color",
      "default": "#FF0000"
    },
    {
      "key": "minuteColor",
      "label": "params.minuteColor",
      "group": "params.groups.colors",
      "kind": "color",
      "default": "#00FF00"
    },
    {
      "key": "secondColor",
      "label": "params.secondColor",
      "group": "params.groups.colors",
      "kind": "color",
      "default": "#0000FF"
    }
  ]
}
