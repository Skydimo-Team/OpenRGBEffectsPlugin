{
  "id": "SwirlCirclesAudio",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/Skydimo-Team/OpenRGBEffectsPlugin",
  "license": "GPL-2.0-or-later",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Disc3",
  "permissions": [
    "audio:capture",
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.motion",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100
    },
    {
      "key": "glow",
      "label": "params.glow",
      "group": "params.groups.appearance",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100
    },
    {
      "key": "radius",
      "label": "params.radius",
      "group": "params.groups.appearance",
      "kind": "slider",
      "default": 0,
      "min": 0,
      "max": 100
    },
    {
      "key": "avgSize",
      "label": "params.smoothness",
      "group": "params.groups.response",
      "kind": "slider",
      "default": 8,
      "min": 1,
      "max": 16,
      "groupCollapsed": true
    },
    {
      "key": "colorMode",
      "label": "params.colorMode",
      "group": "params.groups.color",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.colorModeOptions.randomCycle",
          "value": 0
        },
        {
          "label": "params.colorModeOptions.custom",
          "value": 1
        }
      ]
    },
    {
      "key": "colors",
      "label": "params.colors",
      "group": "params.groups.color",
      "kind": "multi-color",
      "default": [
        "#FF0000",
        "#00FF00"
      ],
      "fixedCount": 2,
      "dependency": {
        "key": "colorMode",
        "equals": 1,
        "behavior": "hide"
      }
    }
  ]
}
