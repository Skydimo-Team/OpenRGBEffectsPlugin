{
  "id": "CustomGradientWave",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/Skydimo-Team/OpenRGBEffectsPlugin",
  "license": "GPL-2.0-or-later",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Waves",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "speed",
      "label": "params.speed",
      "group": "params.groups.animation",
      "kind": "slider",
      "default": 25,
      "min": 1,
      "max": 200,
      "step": 1
    },
    {
      "key": "preset",
      "label": "params.preset",
      "group": "params.groups.palette",
      "kind": "select",
      "default": 1,
      "options": [
        {
          "label": "params.presetOptions.unicornVomit",
          "value": 1
        },
        {
          "label": "params.presetOptions.borealis",
          "value": 2
        },
        {
          "label": "params.presetOptions.ocean",
          "value": 3
        },
        {
          "label": "params.presetOptions.pinkBlue",
          "value": 4
        },
        {
          "label": "params.presetOptions.pinkGold",
          "value": 5
        },
        {
          "label": "params.presetOptions.pulse",
          "value": 6
        },
        {
          "label": "params.presetOptions.purpleOrange",
          "value": 7
        },
        {
          "label": "params.presetOptions.lightBluePurple",
          "value": 8
        },
        {
          "label": "params.presetOptions.policeBeacon",
          "value": 9
        },
        {
          "label": "params.presetOptions.seabed",
          "value": 10
        },
        {
          "label": "params.presetOptions.sunset",
          "value": 11
        },
        {
          "label": "params.presetOptions.vaporwave",
          "value": 12
        },
        {
          "label": "params.presetOptions.custom",
          "value": 0
        }
      ]
    },
    {
      "key": "colors",
      "label": "params.colors",
      "group": "params.groups.palette",
      "kind": "multi-color",
      "default": [
        "#FF0000",
        "#FF00E6",
        "#0000FF",
        "#00B3FF",
        "#00FF51",
        "#EAFF00",
        "#FFB300",
        "#FF0000"
      ],
      "minCount": 2,
      "dependency": {
        "key": "preset",
        "equals": 0,
        "behavior": "hide"
      }
    },
    {
      "key": "direction",
      "label": "params.direction",
      "group": "params.groups.geometry",
      "kind": "select",
      "default": 0,
      "options": [
        {
          "label": "params.directionOptions.horizontal",
          "value": 0
        },
        {
          "label": "params.directionOptions.vertical",
          "value": 1
        },
        {
          "label": "params.directionOptions.radialOut",
          "value": 2
        },
        {
          "label": "params.directionOptions.radialIn",
          "value": 3
        }
      ]
    },
    {
      "key": "height",
      "label": "params.height",
      "group": "params.groups.geometry",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "key": "width",
      "label": "params.width",
      "group": "params.groups.geometry",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "key": "spread",
      "label": "params.spread",
      "group": "params.groups.geometry",
      "kind": "slider",
      "default": 100,
      "min": 0,
      "max": 100,
      "step": 1
    }
  ]
}
