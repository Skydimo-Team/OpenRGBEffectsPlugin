{
  "id": "StarryNight",
  "version": "1.0.0",
  "name": "meta.name",
  "publisher": "Skydimo",
  "description": "meta.description",
  "repository": "https://github.com/Skydimo-Team/OpenRGBEffectsPlugin",
  "license": "GPL-2.0-or-later",
  "type": "effect",
  "language": "lua",
  "entry": "main.lua",
  "category": "meta.category",
  "icon": "Sparkles",
  "permissions": [
    "log"
  ],
  "params": [
    {
      "key": "background",
      "label": "params.background",
      "kind": "color",
      "default": "#000000",
      "group": "params.groups.appearance"
    },
    {
      "key": "bg_brightness",
      "label": "params.bg_brightness",
      "kind": "slider",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1,
      "group": "params.groups.appearance"
    },
    {
      "key": "colors",
      "label": "params.colors",
      "kind": "multi-color",
      "default": [
        "#FFFFFF",
        "#88CCFF",
        "#FFCC44"
      ],
      "minCount": 1,
      "maxCount": 10,
      "group": "params.groups.appearance"
    },
    {
      "key": "density",
      "label": "params.density",
      "kind": "slider",
      "default": 50,
      "min": 10,
      "max": 90,
      "step": 1,
      "group": "params.groups.animation"
    },
    {
      "key": "fade_in_speed",
      "label": "params.fade_in_speed",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100,
      "step": 1,
      "group": "params.groups.animation"
    },
    {
      "key": "fade_out_speed",
      "label": "params.fade_out_speed",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100,
      "step": 1,
      "group": "params.groups.animation"
    },
    {
      "key": "star_on_time",
      "label": "params.star_on_time",
      "kind": "slider",
      "default": 50,
      "min": 1,
      "max": 100,
      "step": 1,
      "group": "params.groups.animation"
    }
  ]
}
